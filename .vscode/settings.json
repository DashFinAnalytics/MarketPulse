{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "files.exclude": {
      "**/__pycache__": true,
      ".venv": true,
      ".pytest_cache": true,
      ".mypy_cache": true,
      ".ruff_cache": true
    },
    "search.exclude": {
      "**/__pycache__": true,
      ".venv": true,
      ".pytest_cache": true,
      ".mypy_cache": true,
      ".ruff_cache": true
    }
}
