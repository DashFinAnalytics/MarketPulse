{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: MarketPulse",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py",
        "--server.port",
        "8501",
        "--browser.gatherUsageStats",
        "false"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
