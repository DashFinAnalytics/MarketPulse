# MarketPulse local environment example
# Copy this file to `.env` and fill in only what you need.
# NOTE: Loading variables from `.env` is not guaranteed by default.
# If your runtime does not automatically load `.env` (e.g., via `python-dotenv`),
# either install/configure such a loader or export these values in your shell
# or deployment environment instead.

# App
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
APP_TITLE=MarketPulse
SHOW_SYSTEM_STATUS=true
ENABLE_AI_ANALYSIS=true
ENABLE_NEWS_FETCHING=true
ENABLE_REAL_TIME_UPDATES=false

# Database (optional)
ENABLE_DATABASE=true
DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.1

# Caching
CACHE_DEFAULT_TTL=300
CACHE_MARKET_DATA_TTL=60
CACHE_NEWS_TTL=900
CACHE_FUNDAMENTAL_TTL=3600

# External data timeouts
YFINANCE_TIMEOUT=10
YFINANCE_RETRY_ATTEMPTS=3
NEWS_SOURCES_TIMEOUT=15
MAX_NEWS_ARTICLES=50
