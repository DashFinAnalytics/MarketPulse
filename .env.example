# Environment variables — copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://marketpulse:marketpulse@localhost:5432/marketpulse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── External Data Providers ───────────────────────────────────────────────────
# Add your data provider API keys here (see docs for supported providers)
MARKET_DATA_API_KEY=

# ── AI Services ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
